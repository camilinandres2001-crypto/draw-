        <!-- CATEGORÍA 3: EXPLOTACIÓN SEXUAL Y PROTECCIÓN DE MENORES -->
        <mxCell id="cat3" value="&lt;b&gt;3. EXPLOTACIÓN SEXUAL&lt;br&gt;Y PROTECCIÓN DE MENORES&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCCC;strokeColor=#C13030;fontColor=#000000;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="140" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="del3.1" value="&lt;b&gt;3.1. Art. 213&lt;br&gt;INDUCCIÓN A LA PROSTITUCIÓN&lt;/b&gt;&lt;br&gt;&lt;br&gt;Persuadir, inducir o convencer a otra persona a dedicarse a la prostitución." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C13030;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="240" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="del3.2" value="&lt;b&gt;3.2. Art. 214&lt;br&gt;CONSTREÑIMIENTO A LA PROSTITUCIÓN&lt;/b&gt;&lt;br&gt;&lt;br&gt;Obligar a una persona a dedicarse a la prostitución, mediante violencia, amenaza o cualquier otra forma de coacción." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C13030;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="355" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="del3.3" value="&lt;b&gt;3.3. Art. 213A&lt;br&gt;PROXENETISMO CON MENOR DE EDAD&lt;/b&gt;&lt;br&gt;&lt;br&gt;Promover, facilitar o favorecer la prostitución de persona menor de 18 años." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C13030;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="485" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="del3.4" value="&lt;b&gt;3.4. Art. 217&lt;br&gt;ESTÍMULO A LA PROSTITUCIÓN DE MENORES&lt;/b&gt;&lt;br&gt;&lt;br&gt;Estimular, favorecer o promocionar la prostitución de niños, niñas o adolescentes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C13030;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="610" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="del3.5" value="&lt;b&gt;3.5. Art. 217A&lt;br&gt;DEMANDA DE EXPLOTACIÓN SEXUAL COMERCIAL DE MENOR DE 18 AÑOS&lt;/b&gt;&lt;br&gt;&lt;br&gt;Solicitar, requerir o adquirir servicios sexuales de persona menor de 18 años, a cambio de cualquier retribución." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C13030;align=center;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="640" y="735" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="del3.6" value="&lt;b&gt;3.6. Art. 218&lt;br&gt;PORNOGRAFÍA CON PERSONAS MENORES DE 18 AÑOS&lt;/b&gt;&lt;br&gt;&lt;br&gt;Producir, fabricar, distribuir, comercializar, importar, exportar, ofrecer, adquirir, poseer o almacenar material pornográfico con personas menores de 18 años." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C13030;align=center;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="640" y="885" width="220" height="120" as="geometry" />
        </mxCell>

