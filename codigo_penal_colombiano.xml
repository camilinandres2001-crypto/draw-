        <mxCell id="del5.1" value="&lt;b&gt;5.1. BIEN JURÍDICO PROTEGIDO&lt;/b&gt;&lt;br&gt;&lt;br&gt;La libertad, integridad y formación sexual de las personas, en especial de niños, niñas y adolescentes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;align=center;fontSize=11;" vertex="1" parent="1">
