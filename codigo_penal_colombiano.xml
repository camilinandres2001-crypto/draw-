        <!-- CATEGORÍA 2: DELITOS CONTRA LA INTEGRIDAD Y FORMACIÓN SEXUAL -->
        <mxCell id="cat2" value="&lt;b&gt;2. DELITOS CONTRA LA&lt;br&gt;INTEGRIDAD Y FORMACIÓN SEXUAL&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE082;strokeColor=#F57F17;fontColor=#000000;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
