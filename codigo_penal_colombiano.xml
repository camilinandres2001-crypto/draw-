        </mxCell>
        <mxCell id="del2.1" value="&lt;b&gt;2.1. Art. 208&lt;br&gt;ACCESO CARNAL ABUSIVO CON MENOR DE 14 AÑOS&lt;/b&gt;&lt;br&gt;&lt;br&gt;Realizar acceso carnal con menor de 14 años, sin que medie violencia." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="240" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="del2.2" value="&lt;b&gt;2.2. Art. 209&lt;br&gt;ACTOS SEXUALES CON MENOR DE 14 AÑOS&lt;/b&gt;&lt;br&gt;&lt;br&gt;Realizar actos sexuales diferentes al acceso carnal con menor de 14 años." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="355" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="del2.3" value="&lt;b&gt;2.3. Art. 210&lt;br&gt;ACCESO CARNAL O ACTO SEXUAL ABUSIVO CON INCAPAZ DE RESISTIR&lt;/b&gt;&lt;br&gt;&lt;br&gt;Realizar acceso carnal o acto sexual con persona que no tenga la capacidad de comprender el hecho o de resistirlo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="480" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="del2.4" value="&lt;b&gt;2.4. Art. 211&lt;br&gt;CIRCUNSTANCIAS DE AGRAVACIÓN PUNITIVA&lt;/b&gt;&lt;br&gt;&lt;br&gt;Aumentan la pena cuando el delito se cometa: con ocasión del parentesco, relación de autoridad o confianza, en concurso de varias personas, con sevicia, o mediante amenaza con armas, entre otras." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;align=center;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="340" y="630" width="220" height="110" as="geometry" />
