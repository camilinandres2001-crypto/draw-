        <mxCell id="del4.2" value="&lt;b&gt;4.2. Art. 219A&lt;br&gt;TURISMO SEXUAL CON MENORES DE EDAD&lt;/b&gt;&lt;br&gt;&lt;br&gt;Viajar al exterior con el propósito de realizar actos sexuales con personas menores de edad." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;align=center;fontSize=10;" vertex="1" parent="1">
