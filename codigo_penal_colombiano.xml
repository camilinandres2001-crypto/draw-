        <mxCell id="del4.1" value="&lt;b&gt;4.1. Art. 219&lt;br&gt;TURISMO SEXUAL&lt;/b&gt;&lt;br&gt;&lt;br&gt;Viajar al exterior con el propósito de realizar actos sexuales remunerados." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;align=center;fontSize=11;" vertex="1" parent="1">
