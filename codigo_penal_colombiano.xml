        <mxCell id="del1.1" value="&lt;b&gt;1.1. Art. 205&lt;br&gt;ACCESO CARNAL VIOLENTO&lt;/b&gt;&lt;br&gt;&lt;br&gt;Acceso carnal mediante violencia sobre la persona." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4F1D4;strokeColor=#228B22;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="del1.2" value="&lt;b&gt;1.2. Art. 206&lt;br&gt;ACTO SEXUAL VIOLENTO&lt;/b&gt;&lt;br&gt;&lt;br&gt;Actos sexuales distintos al acceso carnal, mediante violencia sobre la persona." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4F1D4;strokeColor=#228B22;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="355" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="del1.3" value="&lt;b&gt;1.3. Art. 207&lt;br&gt;ACCESO CARNAL O ACTO SEXUAL EN PERSONA PUESTA EN INCAPACIDAD DE RESISTIR&lt;/b&gt;&lt;br&gt;&lt;br&gt;Aprovechamiento del estado de inconsciencia, enfermedad, intoxicación o cualquier otra causa que anule o disminuya la capacidad de resistir." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4F1D4;strokeColor=#228B22;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="del1.4" value="&lt;b&gt;1.4. Art. 210A&lt;br&gt;ACOSO SEXUAL&lt;/b&gt;&lt;br&gt;&lt;br&gt;Hostigamiento o favoritismo sexual no deseado, verbal, no verbal o físico, que cause perjuicio o ponga en riesgo el empleo, cargo o actividad." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4F1D4;strokeColor=#228B22;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="220" height="110" as="geometry" />
